{
  "name": "yield-pilot",
  "version": "1.0.0",
  "description": "Privacy-preserving autonomous DeFi agent that manages staking yield via Lido, swaps on Uniswap, with private reasoning through Venice — all with onchain receipts.",
  "main": "dist/agent/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "agent": "tsx agent/index.ts",
    "mcp": "tsx mcp/lido-mcp-server.ts",
    "monitor": "tsx agent/services/vaultMonitor.ts",
    "api": "tsx api/server.ts",
    "dev": "concurrently \"npm run agent\" \"npm run monitor\" \"npm run api\"",
    "compile": "npx hardhat compile",
    "deploy": "npx hardhat run scripts/deploy.js --network sepolia",
    "deploy:mock": "npx hardhat run scripts/deploy-mock.ts --network sepolia",
    "mint:mock": "npx hardhat run scripts/mint-mock.ts --network sepolia",
    "simulate:yield": "npx hardhat run scripts/simulate-yield.ts --network sepolia",
    "test": "npx hardhat test",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit && echo '✅ No type errors'"
  },
  "dependencies": {
    "@lido-sdk/contracts": "^3.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@openzeppelin/contracts": "^5.6.1",
    "sql.js": "^1.11.0",
    "@uniswap/sdk-core": "^5.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.0",
    "express": "^4.18.2",
    "node-telegram-bot-api": "^0.66.0",
    "openai": "^4.52.0",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.14.0",
    "@types/node-telegram-bot-api": "^0.64.0",
    "@types/sql.js": "^1.4.10",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.10",
    "chai": "^4.5.0",
    "concurrently": "^8.2.0",
    "hardhat": "^2.22.0",
    "hardhat-gas-reporter": "^1.0.10",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "tsx": "^4.16.0",
    "typechain": "^8.3.2",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "ai-agent",
    "defi",
    "lido",
    "steth",
    "uniswap",
    "venice",
    "erc-8004",
    "mcp",
    "yield-management",
    "privacy",
    "typescript"
  ],
  "license": "MIT"
}
